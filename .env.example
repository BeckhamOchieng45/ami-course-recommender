# ── Groq LLM (coaching-tone reason enhancement) ──────────────────────────────
# Get your key at https://console.groq.com
# When set, every recommendation's coaching_reason field is enhanced by Groq.
# When absent, coaching_reason falls back to the templated reason — no errors.
GROQ_API_KEY=your-groq-api-key-here

# Model — defaults to openai/gpt-oss-120b (fastest, highest quality on Groq)
# GROQ_MODEL=openai/gpt-oss-120b
