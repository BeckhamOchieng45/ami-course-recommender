# Copy this file to .env and fill in your values.
# Never commit .env — it is gitignored.

# ── Groq LLM (coaching-tone reason enhancement) ──────────────────────────────
# Get your key at https://console.groq.com
# When set, every recommendation's coaching_reason is enhanced by Groq.
# When absent, coaching_reason falls back to the templated reason — no errors.
GROQ_API_KEY=your-groq-api-key-here

# Model — defaults to openai/gpt-oss-120b
# GROQ_MODEL=openai/gpt-oss-120b

# ── PostgreSQL (used by Docker Compose) ──────────────────────────────────────
# These values are used inside Docker. Local dev without Docker uses SQLite.
POSTGRES_DB=ami
POSTGRES_USER=ami
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ── Django ────────────────────────────────────────────────────────────────────
# Comma-separated extra hostnames for ALLOWED_HOSTS (optional)
# ALLOWED_HOSTS=myapp.example.com
