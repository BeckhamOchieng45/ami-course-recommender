# ── AMI Course Recommendation Engine — environment variables ─────────────────
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# .env is gitignored — never commit it.
# In production, set these as real environment variables rather than using .env.


# ── Groq LLM ──────────────────────────────────────────────────────────────────
# Get a free key at https://console.groq.com
#
# When set:
#   - Every recommendation's coaching_reason field is re-voiced by the AI coach
#   - The POST /api/chat streaming endpoint activates
#
# When absent:
#   - coaching_reason falls back to the deterministic templated reason
#   - /api/chat returns a fallback message explaining the key is missing
#   - No errors anywhere — the engine degrades gracefully
GROQ_API_KEY=your-groq-api-key-here

# Groq model to use. Default: openai/gpt-oss-120b
# Other options: llama-3.3-70b-versatile, mixtral-8x7b-32768
# GROQ_MODEL=openai/gpt-oss-120b


# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Used by docker-compose. Local dev without Docker uses SQLite automatically
# (no POSTGRES_HOST set → SQLite falls back in settings.py).
#
# IMPORTANT: Change POSTGRES_PASSWORD before deploying anywhere non-local.
POSTGRES_DB=ami
POSTGRES_USER=ami
POSTGRES_PASSWORD=change-me-in-production

# POSTGRES_HOST is set automatically by docker-compose to "db" (the service name).
# Override only if using an external Postgres instance.
# POSTGRES_HOST=db
# POSTGRES_PORT=5432


# ── Django ────────────────────────────────────────────────────────────────────
# Extra hostnames to add to ALLOWED_HOSTS (comma-separated, no spaces).
# localhost, 127.0.0.1, and 0.0.0.0 are always included.
# Example: ALLOWED_HOSTS=myapp.example.com,api.example.com
# ALLOWED_HOSTS=


# ── Gunicorn (Docker only) ────────────────────────────────────────────────────
# Number of worker processes. Rule of thumb: 2 × CPU cores + 1.
# GUNICORN_WORKERS=3

# Worker timeout in seconds. Increase if Groq calls are slow.
# GUNICORN_TIMEOUT=120


# ── Dev mode (Docker only) ────────────────────────────────────────────────────
# Set to 1 to use Django's runserver instead of gunicorn inside Docker.
# Enables live code reloading via the bind-mounted source directories.
# DEV=0
