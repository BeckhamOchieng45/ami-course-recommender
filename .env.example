# ── AMI Course Recommendation Engine ─────────────────────────────────────────
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# .env is gitignored — never commit it.
# In production, prefer real environment variables over this file.


# ── Groq LLM ──────────────────────────────────────────────────────────────────
# Get a free key at https://console.groq.com
#
# When set:
#   - coaching_reason is enhanced by the AI coach on every recommendation
#   - POST /api/chat streaming endpoint is active
#
# When absent:
#   - coaching_reason falls back to the deterministic templated reason
#   - /api/chat returns a graceful fallback message
#   - No errors anywhere — degrades silently
GROQ_API_KEY=your-groq-api-key-here

# Model. Default: openai/gpt-oss-120b
# GROQ_MODEL=openai/gpt-oss-120b


# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Used by docker-compose. Local dev without Docker uses SQLite automatically
# (POSTGRES_HOST not set → SQLite in settings.py).
#
# IMPORTANT: Change POSTGRES_PASSWORD before any non-local deployment.
POSTGRES_DB=ami
POSTGRES_USER=ami
POSTGRES_PASSWORD=change-me-in-production

# POSTGRES_HOST is injected by docker-compose as "db" (Docker internal DNS).
# Leave commented out for local dev — it activates Postgres when set.
# POSTGRES_HOST=db
# POSTGRES_PORT=5432


# ── Django ────────────────────────────────────────────────────────────────────
# Extra comma-separated hostnames for ALLOWED_HOSTS (no spaces).
# localhost and 127.0.0.1 are always included.
# ALLOWED_HOSTS=myapp.example.com,api.example.com


# ── Gunicorn (Docker only) ────────────────────────────────────────────────────
# GUNICORN_WORKERS=3     # Rule of thumb: 2 × CPU cores + 1
# GUNICORN_TIMEOUT=120   # Seconds. Increase if Groq calls are slow.


# ── Dev mode (Docker only) ────────────────────────────────────────────────────
# Set to 1 to use Django's runserver instead of gunicorn (enables live reload).
# DEV=0


# ── Default credentials (created automatically on first run) ──────────────────
# Email:    admin@email.com
# Password: password
# Change these after initial setup. Use Django admin or:
#   python manage.py createsuperuser
